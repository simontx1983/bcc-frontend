# =============================================================================
# bcc-frontend — local environment template
# =============================================================================
# Copy this file to `.env.local` (gitignored) and fill in real values.
# All NEXT_PUBLIC_* vars are inlined into the client bundle. Do NOT put
# secrets there — server-only secrets stay unprefixed.
# =============================================================================

# Backend base URL. The bcc-trust REST namespace lives at /wp-json/bcc/v1/*.
# In Local-by-Flywheel dev, the WP host is usually something like
# http://blue-collar-crypto-custom.local — adjust to whatever Local
# assigned this site.
NEXT_PUBLIC_BCC_API_URL=http://blue-collar-crypto-custom.local

# NextAuth — the canonical URL of THIS Next.js app (no trailing slash).
NEXTAUTH_URL=http://localhost:3000

# NextAuth session secret. Generate once with: openssl rand -base64 32
# This is NOT the BCC JWT secret — NextAuth signs its own session cookie
# with this; the BCC JWT received from /auth/login is stored inside that
# session and verified by the WordPress backend, not by Next.js.
NEXTAUTH_SECRET=replace-with-`openssl rand -base64 32`-output

# Shared secret accepted on the X-Bcc-Internal header by
# /api/internal/verify-wallet-signature. WordPress side defines a
# matching `BCC_INTERNAL_VERIFY_SECRET` constant in wp-config.php.
# Generate once with: openssl rand -base64 32
# This is SEPARATE from BCC_INTERNAL_CRON_SECRET so leaking one
# doesn't widen access to the other.
BCC_INTERNAL_VERIFY_SECRET=replace-with-`openssl rand -base64 32`-output

# Shared secret sent on the X-Bcc-Oauth-Secret header by the NextAuth
# OAuth bridge (lib/auth.ts -> POST /auth/oauth). WordPress defines a
# matching BCC_OAUTH_BRIDGE_SECRET constant in wp-config.php. Only the
# trusted NextAuth backend (which verifies the Google/Twitter token) may
# call /auth/oauth; the secret proves the call originates here. Generate
# with: openssl rand -hex 32. Until set on BOTH ends, OAuth SSO is
# fail-closed (disabled); email/password + wallet login are unaffected.
BCC_OAUTH_BRIDGE_SECRET=replace-with-openssl-rand-hex-32-output

# Shared secret the Vercel cron relay forwards to the WordPress internal
# indexer endpoint (/internal/indexer/tick) on the X-Bcc-Internal header.
# WordPress defines a matching BCC_INTERNAL_CRON_SECRET constant in
# wp-config.php. SEPARATE from BCC_INTERNAL_VERIFY_SECRET on purpose.
# Generate once with: openssl rand -base64 32
# REQUIRED — src/lib/env.ts throws at boot if unset (the cron relay route
# needs it), so a deploy missing this fails fast rather than silently.
BCC_INTERNAL_CRON_SECRET=replace-with-`openssl rand -base64 32`-output

# Vercel-issued secret that authenticates Vercel Cron's own invocation of
# /api/internal/cron/indexer-tick — Vercel sends it as `Authorization:
# Bearer <CRON_SECRET>`, and the route rejects anything else. Set this in
# the Vercel project (Settings → Environment Variables); locally you can
# use any value to exercise the route by hand. REQUIRED by src/lib/env.ts.
CRON_SECRET=replace-with-any-strong-random-string

# Sentry DSN — public per Sentry's threat model (same as a Google
# Analytics ID, safe to inline in the client bundle). Get yours from
# https://blue-collar-crypto.sentry.io/settings/projects/javascript-nextjs/keys/
# Leave unset to disable Sentry locally — it'll no-op gracefully.
NEXT_PUBLIC_SENTRY_DSN=
